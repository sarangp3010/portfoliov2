NODE_ENV=development
PORT=5000

# PostgreSQL — get from Neon, Supabase, or local Docker
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio?schema=public"

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change-this-to-a-very-long-random-string
JWT_EXPIRES_IN=7d

# Gmail SMTP — use an App Password (not your real password)
# Setup: myaccount.google.com → Security → 2-Step → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="Your Name <youremail@gmail.com>"
ADMIN_EMAIL=youremail@gmail.com

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get webhook secret from: stripe listen --forward-to localhost:5000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
