# ─── Database ──────────────────────────────────────────────────────────────────
# Local Docker:  postgresql://portfolio:changeme@localhost:5432/portfolio
# Neon/Supabase: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://portfolio:changeme@localhost:5432/portfolio
POSTGRES_PASSWORD=changeme

# ─── Server ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
NODE_ENV=development
PORT=5000

# ─── Development URLs (single-port proxy on :5173) ─────────────────────────────
# Used by the server for CORS and Stripe redirect URLs during local development.
# These match the subdomain proxy — no changes needed unless you change PROXY_PORT.
CLIENT_URL=http://public.localhost:5173
CUSTOMER_URL=http://customer.localhost:5173

# ─── Production URLs (set these for staging/prod deployments) ──────────────────
# PUBLIC_URL=https://public.example.com
# CUSTOMER_URL=https://customer.example.com
# VITE_API_URL=https://api.example.com

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: use an App Password — myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@example.com
ADMIN_EMAIL=admin@example.com

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from: stripe listen --forward-to localhost:5173/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── SMS / Twilio (optional) ───────────────────────────────────────────────────
# If not set, SMS notifications are silently skipped — no errors thrown.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15550001234

# ─── OAuth / Social Login (optional) ──────────────────────────────────────────
# See docs/customer-portal.md for setup instructions
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
